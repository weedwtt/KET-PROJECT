// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Master Tables ─────────────────────────────────────────────────────────────

/// คำนำหน้าชื่อ เช่น เด็กชาย, เด็กหญิง, นาย, นาง, นางสาว
model Title {
  id       Int       @id @default(autoincrement())
  name     String    @unique @db.VarChar(50)
  students Student[]

  @@map("titles")
}

/// สถานะผู้ปกครอง เช่น พ่อ, แม่, ปู่, ย่า, อื่นๆ
model GuardianRelation {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(50)
  guardians Guardian[]

  @@map("guardian_relations")
}

// ─── Core Tables ───────────────────────────────────────────────────────────────

model Student {
  id               Int               @id @default(autoincrement())
  statementRecords StatementRecord[]
  bondRecords      BondRecord[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ────── ข้อมูลทะเบียนนักเรียน ──────
  /// รหัสนักเรียน เช่น 42344 — unique, indexed สำหรับค้นหา
  studentCode String @unique @db.VarChar(20) @map("student_code")

  /// เลขที่ในห้อง เช่น 1, 2, 3
  classNumber Int @map("class_number")

  /// ระดับชั้น เช่น ม.1, ม.2, ป.6
  gradeLevel String @db.VarChar(20) @map("grade_level")

  /// ห้องเรียน เช่น 1, 2, 3 (ม.1/1 = gradeLevel "ม.1" + classRoom 1)
  classRoom Int @map("class_room")

  // ────── ชื่อ ──────
  titleId Int   @map("title_id")
  title   Title @relation(fields: [titleId], references: [id])

  firstName String @db.VarChar(100) @map("first_name")
  lastName  String @db.VarChar(100) @map("last_name")

  // ────── ข้อมูลส่วนตัว ──────
  birthDate  DateTime @map("birth_date") @db.Date
  nationalId String   @unique @db.Char(13) @map("national_id")
  phone      String?  @db.VarChar(30)

  nationality String  @db.VarChar(100)
  ethnicity   String  @db.VarChar(100)
  religion    String  @db.VarChar(100)
  bloodType   String? @db.VarChar(10) @map("blood_type")

  // ────── ที่อยู่ ──────
  addressHouseNo     String  @db.VarChar(50)  @map("address_house_no")
  addressMoo         String? @db.VarChar(30)  @map("address_moo")
  addressVillage     String? @db.VarChar(100) @map("address_village")
  addressRoad        String? @db.VarChar(100) @map("address_road")
  addressSoi         String? @db.VarChar(100) @map("address_soi")
  addressSubDistrict String  @db.VarChar(100) @map("address_sub_district")
  addressDistrict    String  @db.VarChar(100) @map("address_district")
  addressProvince    String  @db.VarChar(100) @map("address_province")
  addressPostalCode  String  @db.Char(5)      @map("address_postal_code")

  // ────── Relations ──────
  guardians Guardian[]
  advisors  StudentAdvisor[]

  // ────── Indexes สำหรับการค้นหา ──────
  @@index([firstName, lastName], map: "idx_student_name")
  @@index([firstName], map: "idx_student_first_name")
  @@index([lastName], map: "idx_student_last_name")
  @@index([gradeLevel, classRoom], map: "idx_student_class")

  @@map("students")
}

/// คำนำหน้าชื่อครู เช่น นาย, นาง, นางสาว, ดร., ผศ.
model TeacherTitle {
  id       Int       @id @default(autoincrement())
  name     String    @unique @db.VarChar(50)
  teachers Teacher[]

  @@map("teacher_titles")
}

// ─── Teacher Enums ─────────────────────────────────────────────────────────────

/// บทบาทของครู
enum TeacherRole {
  DIRECTOR      @map("DIRECTOR")
  VICE_DIRECTOR @map("VICE_DIRECTOR")
  TEACHER       @map("TEACHER")
  ADMIN         @map("ADMIN")
  DISCIPLINE    @map("DISCIPLINE")
  SUPER_ADMIN   @map("SUPER_ADMIN")
}

/// ระดับชั้นที่ครูดูแล (ใช้สำหรับหัวหน้าระดับชั้น)
enum GradeHeadLevel {
  M1 @map("ม.1")
  M2 @map("ม.2")
  M3 @map("ม.3")
  M4 @map("ม.4")
  M5 @map("ม.5")
  M6 @map("ม.6")
}

// ─── Teacher ───────────────────────────────────────────────────────────────────

model Teacher {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ────── ชื่อ ──────
  titleId   Int          @map("title_id")
  title     TeacherTitle @relation(fields: [titleId], references: [id])

  firstName String @db.VarChar(100) @map("first_name")
  lastName  String @db.VarChar(100) @map("last_name")

  // ────── ติดต่อ ──────
  phone String @db.VarChar(30)

  // ────── ที่อยู่ ──────
  addressHouseNo     String  @db.VarChar(50)  @map("address_house_no")
  addressMoo         String? @db.VarChar(30)  @map("address_moo")
  addressVillage     String? @db.VarChar(100) @map("address_village")
  addressRoad        String? @db.VarChar(100) @map("address_road")
  addressSoi         String? @db.VarChar(100) @map("address_soi")
  addressSubDistrict String  @db.VarChar(100) @map("address_sub_district")
  addressDistrict    String  @db.VarChar(100) @map("address_district")
  addressProvince    String  @db.VarChar(100) @map("address_province")
  addressPostalCode  String  @db.Char(5)      @map("address_postal_code")

  // ────── บทบาท ──────
  /// บทบาทของครู: DIRECTOR, VICE_DIRECTOR, TEACHER, ADMIN
  role           TeacherRole?

  /// ระดับชั้นที่ดูแลในฐานะหัวหน้าระดับชั้น (M1–M6) null = ไม่ได้เป็นหัวหน้าระดับชั้น
  gradeHeadLevel GradeHeadLevel? @map("grade_head_level")

  // ────── ลายเซ็น ──────
  /// path ของไฟล์ลายเซ็น เก็บใน local storage หรือ cloud (เช่น /uploads/signatures/42.png)
  /// null = ยังไม่ได้อัปโหลดลายเซ็น
  signatureUrl       String?   @db.Text @map("signature_url")
  signatureUpdatedAt DateTime? @map("signature_updated_at")

  advisorOf              StudentAdvisor[]
  disciplineStatements   StatementRecord[] @relation("DisciplineTeacher")
  gradeHeadStatements    StatementRecord[] @relation("GradeHeadTeacher")
  approvedStatements     StatementRecord[] @relation("ApprovedBy")
  signatureStatements    StatementRecord[] @relation("SignatureTeacher")
  bondHeadTeacher        BondRecord[]      @relation("BondHeadTeacher")
  bondDisciplineTeacher  BondRecord[]      @relation("BondDisciplineTeacher")
  bondApprovals          BondRecord[]      @relation("BondApprovedBy")
  user                   User?
  delegatedTo            ApprovalDelegate[] @relation("PrincipalDelegates")
  delegateFor            ApprovalDelegate[] @relation("TeacherDelegates")

  @@index([firstName, lastName], map: "idx_teacher_name")

  @@map("teachers")
}

model Guardian {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  firstName String @db.VarChar(100) @map("first_name")
  lastName  String @db.VarChar(100) @map("last_name")
  phone     String @db.VarChar(20)

  relationId Int              @map("relation_id")
  relation   GuardianRelation @relation(fields: [relationId], references: [id])

  bonds      StatementBond[]
  bondRecords BondRecord[]

  @@index([studentId], map: "idx_guardian_student")

  @@map("guardians")
}

// ─── Advisor Relationship ──────────────────────────────────────────────────────

/// ความสัมพันธ์ครูที่ปรึกษา — นักเรียน 1 คน มีครูที่ปรึกษาได้ไม่เกิน 2 คน
/// slot 1 = ครูที่ปรึกษาคนที่ 1, slot 2 = ครูที่ปรึกษาคนที่ 2
model StudentAdvisor {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  teacherId Int     @map("teacher_id")
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  /// ลำดับครูที่ปรึกษา: 1 หรือ 2
  slot Int

  /// นักเรียน 1 คน ต่อ slot ได้ 1 ครูเท่านั้น
  @@unique([studentId, slot], map: "uq_student_advisor_slot")

  @@index([teacherId], map: "idx_advisor_teacher")

  @@map("student_advisors")
}

// ─── Discipline Master Tables ──────────────────────────────────────────────────

/// ผู้บันทึก — รายชื่อผู้บันทึกถ้อยคำนักเรียน
model Recorder {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(200)

  @@map("recorders")
}

model Semester {
  id               Int               @id @default(autoincrement())
  name             String            @unique @db.VarChar(50)
  value            Int               @unique
  statementRecords StatementRecord[]
  bondRecords      BondRecord[]

  @@map("semesters")
}

model AcademicYear {
  id               Int               @id @default(autoincrement())
  year             Int               @unique
  statementRecords StatementRecord[]
  bondRecords      BondRecord[]

  @@map("academic_years")
}

model ViolationCategory {
  id               Int                    @id @default(autoincrement())
  name             String                 @unique @db.VarChar(200)
  subCategories    ViolationSubCategory[]
  statementRecords StatementRecord[]

  @@map("violation_categories")
}

model ViolationSubCategory {
  id                  Int               @id @default(autoincrement())
  name                String            @db.VarChar(300)
  violationCategoryId Int               @map("violation_category_id")
  violationCategory   ViolationCategory @relation(fields: [violationCategoryId], references: [id], onDelete: Cascade)
  statementRecords    StatementRecord[]

  @@index([violationCategoryId], map: "idx_sub_category_parent")
  @@map("violation_sub_categories")
}

// ─── Disciplinary Records ──────────────────────────────────────────────────────

model StatementRecord {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [id])

  recordDate   DateTime @map("record_date") @db.Date

  semesterId          Int               @map("semester_id")
  semester            Semester          @relation(fields: [semesterId], references: [id])

  academicYearId      Int               @map("academic_year_id")
  academicYear        AcademicYear      @relation(fields: [academicYearId], references: [id])

  violationCategoryId    Int               @map("violation_category_id")
  violationCategory      ViolationCategory @relation(fields: [violationCategoryId], references: [id])

  violationSubCategoryId Int?                  @map("violation_sub_category_id")
  violationSubCategory   ViolationSubCategory? @relation(fields: [violationSubCategoryId], references: [id])

  subject    String   @db.VarChar(500)
  content    String   @db.Text
  incidentAt DateTime? @map("incident_at")
  location   String?   @db.VarChar(200)

  advisor1Name String? @db.VarChar(200) @map("advisor1_name")
  advisor2Name String? @db.VarChar(200) @map("advisor2_name")
  recordedBy   String? @db.VarChar(200) @map("recorded_by")

  // ────── Step 4: มาตรการ ──────
  /// รหัสมาตรการพิจารณา เช่น ["notify_parent", "invite_parent"]
  considerationMeasures String[] @default([]) @map("consideration_measures")
  /// รหัสผลการพิจารณา เช่น ["verbal_warning", "deduct_score"]
  resultMeasures        String[] @default([]) @map("result_measures")
  measureNotes          String?  @db.Text @map("measure_notes")

  // ────── Step 5: ลายเซ็น ──────
  studentSignature  String? @db.Text @map("student_signature")
  guardianSignature String? @db.Text @map("guardian_signature")
  advisorSignature  String? @db.Text @map("advisor_signature")

  disciplineTeacherId Int?     @map("discipline_teacher_id")
  disciplineTeacher   Teacher? @relation("DisciplineTeacher", fields: [disciplineTeacherId], references: [id])

  /// ลายเซ็นสดของครูฝ่ายปกครอง (data URL) — ใช้เมื่อเซ็นสด ณ ที่เกิดเหตุ แทนการดึงจากระบบ
  disciplineTeacherSignature String? @db.Text @map("discipline_teacher_signature")

  gradeHeadTeacherId Int?     @map("grade_head_teacher_id")
  gradeHeadTeacher   Teacher? @relation("GradeHeadTeacher", fields: [gradeHeadTeacherId], references: [id])

  /// ลายเซ็นสดของหัวหน้าระดับชั้น (data URL) — ใช้เมื่อเซ็นสด ณ ที่เกิดเหตุ แทนการดึงจากระบบ
  gradeHeadSignature String? @db.Text @map("grade_head_signature")

  // ────── Step 5 (Bond): ทัณฑ์บน ──────
  bond StatementBond?

  // ────── สถานะการอนุมัติ ──────
  /// "pending_discipline_teacher" = รอครูฝ่ายปกครองลงนาม, "pending_grade_head" = รอหัวหน้าระดับลงนาม, "pending" = รอดำเนินการ, "approved" = อนุมัติแล้ว
  status              String   @default("pending") @db.VarChar(30)
  approvedByTeacherId Int?     @map("approved_by_teacher_id")
  approvedByTeacher   Teacher? @relation("ApprovedBy", fields: [approvedByTeacherId], references: [id])
  /// ครูที่ใช้ลายเซ็นในเอกสาร (อาจต่างจาก approvedByTeacher เมื่อผู้รับมอบอำนาจอนุมัติแทน)
  signatureTeacherId  Int?     @map("signature_teacher_id")
  signatureTeacher    Teacher? @relation("SignatureTeacher", fields: [signatureTeacherId], references: [id])
  approvedAt          DateTime? @map("approved_at")

  /// ความเห็นรองผู้อำนวยการ / ผู้อำนวยการ (พิมพ์ตอนอนุมัติ ไม่บังคับ) — แสดงในช่องความเห็นของ PDF
  viceDirectorComment String? @db.Text @map("vice_director_comment")
  directorComment     String? @db.Text @map("director_comment")

  @@index([studentId], map: "idx_statement_student")
  @@index([recordDate], map: "idx_statement_date")

  @@map("statement_records")
}

// ─── User (Login) ─────────────────────────────────────────────────────────────

/// บัญชีผู้ใช้สำหรับเข้าสู่ระบบ — ผูกกับครู 1 คน (1:1)
model User {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  username     String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash") @db.VarChar(255)

  /// null = super admin (ไม่ผูกกับครูคนใด)
  teacherId    Int?     @unique @map("teacher_id")
  teacher      Teacher? @relation(fields: [teacherId], references: [id])

  @@map("users")
}

/// สัญญาทัณฑ์บน — สร้างเมื่อเลือกมาตรการ "ทำทัณฑ์บน" เท่านั้น
model StatementBond {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  statementRecordId Int             @unique @map("statement_record_id")
  statementRecord   StatementRecord @relation(fields: [statementRecordId], references: [id], onDelete: Cascade)

  guardianId Int      @map("guardian_id")
  guardian   Guardian @relation(fields: [guardianId], references: [id])

  /// บทลงโทษหากทำผิดซ้ำ เช่น ["deduct_score", "suspension"]
  penaltyActions String[] @default([]) @map("penalty_actions")

  /// จำนวนคะแนนที่ตัด (ใช้เมื่อ penaltyActions มี "deduct_score")
  deductPoints Int? @map("deduct_points")

  witnessName String? @db.VarChar(200) @map("witness_name")

  @@map("statement_bonds")
}

// ─── Approval Delegates ───────────────────────────────────────────────────────

/// ผู้รับมอบอำนาจอนุมัติแทน — ผอ/รองผอ มอบสิทธิ์อนุมัติให้ครูคนอื่นได้
model ApprovalDelegate {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now()) @map("created_at")

  /// ผอ/รองผอ ที่มอบอำนาจ
  principalId Int      @map("principal_id")
  principal   Teacher  @relation("PrincipalDelegates", fields: [principalId], references: [id], onDelete: Cascade)

  /// ครูที่ได้รับมอบอำนาจให้อนุมัติแทน
  delegateId  Int      @map("delegate_id")
  delegate    Teacher  @relation("TeacherDelegates", fields: [delegateId], references: [id], onDelete: Cascade)

  @@unique([principalId, delegateId])
  @@map("approval_delegates")
}

// ─── Bond Record (standalone) ─────────────────────────────────────────────────

/// บันทึกทัณฑ์บนแบบอิสระ (ไม่ผูกกับบันทึกถ้อยคำ)
model BondRecord {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [id])

  contractDate DateTime @map("contract_date")

  semesterId     Int?         @map("semester_id")
  semester       Semester?    @relation(fields: [semesterId], references: [id])
  academicYearId Int?         @map("academic_year_id")
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])

  /// ข้อมูลผู้ปกครอง (denormalized เพื่อให้แก้ไขได้หลัง auto-fill)
  guardianId       Int?    @map("guardian_id")
  guardian         Guardian? @relation(fields: [guardianId], references: [id])
  guardianName     String  @db.VarChar(200) @map("guardian_name")
  guardianRelation String  @db.VarChar(100) @map("guardian_relation")
  guardianPhone    String? @db.VarChar(30)  @map("guardian_phone")

  /// ที่อยู่ผู้ปกครอง
  addressHouseNo   String? @db.VarChar(20)  @map("address_house_no")
  addressMoo       String? @db.VarChar(10)  @map("address_moo")
  addressVillage   String? @db.VarChar(100) @map("address_village")
  addressRoad      String? @db.VarChar(100) @map("address_road")
  addressSoi       String? @db.VarChar(100) @map("address_soi")
  addressSubDistrict String? @db.VarChar(100) @map("address_sub_district")
  addressDistrict  String? @db.VarChar(100) @map("address_district")
  addressProvince  String? @db.VarChar(100) @map("address_province")

  /// รายละเอียดการกระทำผิด
  violationDetail  String  @db.Text @map("violation_detail")

  /// มาตรการที่จะดำเนินการหากทำผิดซ้ำ
  measureDeductScore   Boolean @default(false) @map("measure_deduct_score")
  measureDeductPoints  Int?    @map("measure_deduct_points")
  measureActivity      Boolean @default(false) @map("measure_activity")
  measureSuspension    Boolean @default(false) @map("measure_suspension")
  measureTransfer      Boolean @default(false) @map("measure_transfer")

  /// ผู้บันทึก
  recorder String @db.VarChar(200)

  /// สถานะ: active | expired | closed
  status String @default("active") @db.VarChar(20)

  /// ลายเซ็น (base64 PNG)
  guardianSignature    String? @db.Text @map("guardian_signature")
  studentSignature     String? @db.Text @map("student_signature")
  advisorSignature     String? @db.Text @map("advisor_signature")
  headTeacherId        Int?    @map("head_teacher_id")
  headTeacher          Teacher? @relation("BondHeadTeacher", fields: [headTeacherId], references: [id])
  /// ลายเซ็นสดของหัวหน้าระดับชั้น (data URL) — ใช้เมื่อเซ็นสด ณ ที่เกิดเหตุ
  headTeacherSignature String? @db.Text @map("head_teacher_signature")
  disciplineTeacherId  Int?    @map("discipline_teacher_id")
  disciplineTeacher    Teacher? @relation("BondDisciplineTeacher", fields: [disciplineTeacherId], references: [id])
  /// ลายเซ็นสดของครูฝ่ายปกครอง (data URL) — ใช้เมื่อเซ็นสด ณ ที่เกิดเหตุ แทนการดึงจากระบบ
  disciplineTeacherSignature String? @db.Text @map("discipline_teacher_signature")
  viceDirectorSignature String? @db.Text @map("vice_director_signature")
  directorSignature    String? @db.Text @map("director_signature")

  /// ความเห็นรองผู้อำนวยการ / ผู้อำนวยการ (พิมพ์ตอนอนุมัติ ไม่บังคับ) — แสดงในช่องความเห็นของ PDF
  viceDirectorComment  String? @db.Text @map("vice_director_comment")
  directorComment      String? @db.Text @map("director_comment")

  advisor1Name         String? @db.VarChar(200) @map("advisor1_name")
  advisor2Name         String? @db.VarChar(200) @map("advisor2_name")

  approvedByTeacherId  Int?     @map("approved_by_teacher_id")
  approvedByTeacher    Teacher? @relation("BondApprovedBy", fields: [approvedByTeacherId], references: [id])
  approvedAt           DateTime? @map("approved_at")

  @@index([studentId], map: "idx_bond_student")
  @@index([contractDate], map: "idx_bond_date")

  @@map("bond_records")
}
